{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "@microsoft/kiota",
  "version": "1.25.1",
  "description": "npm package exposing Kiota CLI functionality to TypeScript",
  "repository": {
    "url": "https://github.com/microsoft/kiota.git",
    "type": "git"
  },
  "directories": {
    "lib": "lib",
    "test": "tests"
  },
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "type": "module",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "lint": "eslint",
    "test": "jest --runInBand",
    "test:unit": "jest --config=jest.config.unit.cjs",
    "test:integration": "jest --config=jest.config.integration.cjs --runInBand",
    "build": "npm run clean && tsc --project ./tsconfig.json",
    "clean": "rimraf dist",
    "generate-readme": "node scripts/generate-readme.cjs",
    "test:coverage": "jest --coverage --runInBand",
    "prepack": "npm run build",
    "package": "npm pack"
  },
  "keywords": [
    "Kiota"
  ],
  "author": "Microsoft",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.6.0",
    "original-fs": "^1.2.0",
    "uuid": "^14.0.1",
    "vscode-jsonrpc": "^8.2.1"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/jest": "^30.0.0",
    "glob": "^13.0.6",
    "jest": "^30.4.2",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.12",
    "ts-loader": "^9.6.2"
  }
}
